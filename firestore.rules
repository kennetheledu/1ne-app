rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if request.auth != null;
      // Only allow writes to specific collections that aren't managed by functions
      allow write: if false; 
    }
    
    match /users/{uid} {
      allow read: if request.auth != null;
    }
    
    match /taskSubmissions/{subId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
    }

    // Callables handle the complex logic for Wallets, Transactions, and Favors.
    // No client-side writes allowed for those.
  }
}
