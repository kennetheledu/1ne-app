rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    
    function getMyData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function sameCouple(coupleId) {
      return getMyData().coupleId == coupleId;
    }
    
    match /users/{uid} {
      allow read: if isAuth() && (isOwner(uid) || sameCouple(resource.data.coupleId));
      allow write: if isAuth() && isOwner(uid);
    }
    
    match /wallets/{uid} {
      allow read, write: if isAuth() && isOwner(uid);
    }
    
    match /streaks/{uid} {
      allow read, write: if isAuth() && isOwner(uid);
    }
    
    match /tasks/{taskId} {
      allow read, write: if request.auth != null && (
        resource.data.assignedTo == request.auth.uid ||
        (resource.data.coupleId != null && 
         get(/databases/$(database)/documents/users/$(request.auth.uid))
           .data.coupleId == resource.data.coupleId)
      );
      allow create: if isAuth();
    }
    
    match /taskSubmissions/{subId} {
      allow read, write: if request.auth != null && (
        resource.data.submittedBy == request.auth.uid ||
        resource.data.assignedPartner == request.auth.uid ||
        (resource.data.coupleId != null && 
         get(/databases/$(database)/documents/users/$(request.auth.uid))
           .data.coupleId == resource.data.coupleId)
      );
      allow create: if isAuth();
    }
    
    match /transactions/{txId} {
      allow read: if isAuth() && isOwner(resource.data.uid);
      allow create: if isAuth();
    }
    
    match /favorRequests/{reqId} {
      allow read, write: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        (resource.data.coupleId != null &&
         get(/databases/$(database)/documents/users/$(request.auth.uid))
           .data.coupleId == resource.data.coupleId)
      );
      allow create: if isAuth();
      
      match /thread/{msgId} {
        allow read, write: if isAuth();
      }
      match /negotiations/{negId} {
        allow read, write: if isAuth();
      }
    }
    
    match /threads/{threadId} {
      allow read, write: if isAuth() && sameCouple(resource.data.coupleId);
      allow create: if isAuth();
      
      match /messages/{msgId} {
        allow read, write: if isAuth();
      }
    }
    
    match /notifications/{notifId} {
      allow read, write: if isAuth() && isOwner(resource.data.uid);
      allow create: if isAuth();
    }
    
    match /auditLogs/{logId} {
      allow read: if isAuth();
      allow create: if isAuth();
    }
  }
}
