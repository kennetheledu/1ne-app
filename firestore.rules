rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Common check for authenticated users
    function isAuthenticated() {
      return request.auth != null;
    }

    // Admin role check
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /wallets/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        request.auth.uid == uid || 
        // Allow linking: partner updates coupleId and partnerId if inviteCode matches
        (resource.data.inviteCode != null && 
         request.resource.data.inviteCode == null &&
         request.resource.data.coupleId != null &&
         request.resource.data.partnerId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coupleId', 'partnerId', 'inviteCode']))
      );
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /threads/{threadId} {
      allow read, write: if isAuthenticated();
      match /messages/{msgId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /favorRequests/{favorId} {
      allow read, write: if isAuthenticated();
    }

    match /auditLogs/{logId} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated();
    }

    match /transactions/{txId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.uid;
      allow write: if isAuthenticated();
    }

    match /streaks/{uid} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
